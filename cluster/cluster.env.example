# ============================================================
# GX10 Dual-Node Cluster Configuration
# Edit this file first. Both scripts source it.
# ============================================================

# Role IPs on the ConnectX-7 point-to-point link (do not use your LAN subnet)
HEAD_IP="192.168.100.10"
WORKER_IP="192.168.100.11"
CX7_SUBNET_PREFIX="24"

# SSH user on both nodes (must match your login on each GX10)
CLUSTER_USER="neal"

# Worker node hostname or management LAN IP (used for SSH from head, NOT the CX7 link,
# until the CX7 link is up; after setup you can switch this to $WORKER_IP)
WORKER_SSH_HOST="192.168.100.11"

# vLLM container image (ARM64 / GB10 sm_121 build from NGC).
# Pin a specific tag once you validate it; check https://catalog.ngc.nvidia.com for latest.
VLLM_IMAGE="nvcr.io/nvidia/vllm:26.01-py3"

# Model to serve and parallelism
MODEL="openai/gpt-oss-120b"
TENSOR_PARALLEL=2
MAX_MODEL_LEN=65536

# UMA safety margin. GB10 shares RAM between CPU and GPU.
# 0.80 to 0.85 is the safe band; lower it if other services run on the boxes.
GPU_MEM_UTIL=0.80

# Hugging Face token for gated models (leave empty if not needed)
HF_TOKEN=""

# Ports
API_PORT=8000
RAY_PORT=6379
RAY_DASHBOARD_PORT=8265

# Host path for model cache (persisted across container restarts, synced per node)
HF_CACHE_DIR="/data/hf-cache"

# ============================================================
# NCCL / ConnectX-7 RDMA tuning
# ------------------------------------------------------------
# GB10 has NO GPUDirect RDMA (unified memory can't be DMA'd by the NIC), so the
# bundled AWS-OFI NCCL plugin fails and NCCL silently falls back to TCP (~1-3 GB/s).
# NCCL_NET_PLUGIN=none forces NCCL's native IB-verbs path (host-staged) -> RDMA works.
# These values are verified on this 2x GX10 setup; find yours with `ibdev2netdev`
# (HCA device names) and `show_gids` (the RoCEv2/IPv4 GID index, usually 3).
# ============================================================

# RoCE HCA device(s) NCCL pins to. MUST be set or NCCL may pick a GID-less port and
# fall back to TCP. Single rail: "rocep1s0f1". Dual rail (one cable per ConnectX-7,
# on separate PCIe roots): "rocep1s0f1,roceP2p1s0f1".
IB_HCA="rocep1s0f1,roceP2p1s0f1"

# RoCEv2 IPv4 GID index (from `show_gids`; usually 3).
IB_GID_INDEX="3"

# NCCL 2.30.x on GB10 can hang on MoE weight load (e.g. gpt-oss-120b) with NVLS on.
NCCL_NVLS_ENABLE="0"

# Dual-rail merge + queue-pair tuning. Each ConnectX-7 is PCIe Gen5 x4 (~14 GB/s
# ceiling), so a single rail caps ~14 GB/s; merging two NICs reaches ~24 GB/s.
NCCL_IB_MERGE_NICS="1"
NCCL_CROSS_NIC="1"
NCCL_IB_QPS_PER_CONNECTION="4"
NCCL_IB_SPLIT_DATA_ON_QPS="1"

# ============================================================
# Second RDMA rail (optional dual-rail; leave RAIL2_IFACE empty for single-rail)
# ------------------------------------------------------------
# The 2nd ConnectX-7 is on a separate PCIe root, so a cable on it adds real
# bandwidth. That NIC is NetworkManager-unmanaged, so 01-node-setup.sh installs a
# systemd one-shot (gx10-rail2.service) to bring it up on boot on a 2nd subnet.
# ============================================================
RAIL2_IFACE="enP2p1s0f1np1"
RAIL2_HEAD_IP="192.168.102.10"
RAIL2_WORKER_IP="192.168.102.11"
